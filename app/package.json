{
  "name": "cozycast",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "EXPO_PUBLIC_COMMIT_REF=\"${COMMIT_REF:-}\" expo export --platform web --source-maps && bash scripts/upload-sourcemaps.sh dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "fixtures": "node scripts/seed-fixtures.mjs",
    "db:reset": "supabase db reset --workdir ..",
    "dev:seed": "npm run db:reset && npm run fixtures",
    "check": "npm run lint && npm run format:check && npm test"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@supabase/.*))"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/metro-runtime": "~4.0.0",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@sentry/react-native": "~6.10.0",
    "@supabase/supabase-js": "^2.47.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.0",
    "expo-av": "~15.0.2",
    "expo-clipboard": "~7.0.1",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@playwright/test": "^1.61.0",
    "@sentry/cli": "^2.58.6",
    "@testing-library/react-native": "^12.9.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.6",
    "prettier": "^3.8.4",
    "react-test-renderer": "^18.3.1",
    "supabase": "^2.107.0"
  },
  "private": true
}
