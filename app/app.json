{
  "expo": {
    "name": "cozycast",
    "slug": "cozycast",
    "scheme": "cozycast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFF8F0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cozycast.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "cozycast needs microphone access to record audio casts.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.cozycast.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@sentry/react-native",
      [
        "expo-image-picker",
        {
          "photosPermission": "cozycast needs photo access so you can set a profile picture."
        }
      ]
    ]
  }
}
