# Copy to .env and fill in. EXPO_PUBLIC_* vars are inlined into the build.
# The same vars are configured in the Netlify build environment for deploys.

# Supabase project — Dashboard → Project Settings → API (required)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Base URL for email-confirmation redirects.
# Optional locally; defaults to https://cozycast.jall.me when unset.
EXPO_PUBLIC_SITE_URL=

# Sentry error tracking — Project Settings → Client Keys (DSN).
# Optional; reporting stays off (and is disabled in dev) when unset.
EXPO_PUBLIC_SENTRY_DSN=
